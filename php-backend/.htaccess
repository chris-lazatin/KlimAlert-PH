# KlimAlert PH · Apache hardening
# Drop this folder into XAMPP's htdocs/klimalert-api or your shared host root.

# Disable directory listings
Options -Indexes

# Block access to includes & sql files
<FilesMatch "\.(sql|md|env|ini|log)$">
  Require all denied
</FilesMatch>

# Block access to lib/ from the web (only PHP scripts include it)
RedirectMatch 403 ^/.*/lib/.*$
RedirectMatch 403 ^/.*/config\.php$

# Force UTF-8
AddDefaultCharset UTF-8

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(self), camera=()"
</IfModule>

# Make the api endpoints prettier (optional)
<IfModule mod_rewrite.c>
  RewriteEngine On
  # /auth/login  →  /auth/login.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>
